{
  "name": "migros-b2b-system",
  "version": "1.0.0",
  "description": "Migros B2B Reporting and Analytics System",
  "main": "backend/server.js",
  "scripts": {
    "build": "npm --prefix client run build",
    "start": "concurrently \"node server.js\" \"node agent.js\"",
    "agent": "node agent.js",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "migros",
    "b2b",
    "reporting",
    "analytics",
    "sales"
  ],
  "author": "Kittycady",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "concurrently": "^8.2.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
